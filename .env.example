# Database
DATABASE_URL=postgresql+asyncpg://estimation:estimation@localhost:5432/estimation
SYNC_DATABASE_URL=postgresql+psycopg2://estimation:estimation@localhost:5432/estimation

# Celery / Redis
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Calculation settings
CALCULATION_TTL_SECONDS=86400
HEARTBEAT_TIMEOUT_SECONDS=60
MAX_ITEMS_PER_CALCULATION=500
MAX_PAYLOAD_SIZE_BYTES=1048576
MAX_CONCURRENT_JOBS=4
MAX_CONCURRENT_PROVIDER_REQUESTS=10
PRICE_PROVIDER_TIMEOUT_SECONDS=3.0
MAX_JOB_RETRIES=2

# API Key Authentication (comma-separated list)
# Leave empty to disable authentication (development mode)
API_KEYS=dev-key-1,dev-key-2
